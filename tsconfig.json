{
    "compilerOptions": {
        "target": "ESNext",
        "lib": ["DOM", "DOM.Iterable", "ESNext", "WebWorker"],
        "allowJs": true,
        "skipLibCheck": true,
        "esModuleInterop": true,
        "allowSyntheticDefaultImports": true,
        "strict": true,
        "forceConsistentCasingInFileNames": true,
        "module": "ESNext",
        "moduleResolution": "Node",
        "baseUrl": ".",
        "paths": {
            "revolt.js": ["./external/revolt.js/lib/index.js"],
            "revolt.js/esm/maps/Emojis": ["./external/revolt.js/esm/maps/Emojis.js"]
        },
        "resolveJsonModule": true,
        "isolatedModules": true,
        "noEmit": true,
        "jsx": "preserve",
        "jsxImportSource": "preact",
        "jsxFactory": "h",
        "jsxFragmentFactory": "Fragment",
        "types": ["vite-plugin-pwa/client"],
        "experimentalDecorators": true
    },
    "include": ["src", "external/lang/Languages.ts", "external/revolt.js/lib/**/*", "external/revolt.js/esm/**/*"]
}
